PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (replace user/password/cluster)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/wastezero?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

# CORS — Angular dev server
CLIENT_URL=http://localhost:4200
